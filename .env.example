# ── Runtime ────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=development
# Port the API listens on
PORT=4000

# ── Database (required) ────────────────────────────────────────────────
# PostgreSQL connection string: postgresql://user:password@host:5432/db
DATABASE_URL=

# ── Redis (required) ───────────────────────────────────────────────────
# redis:// or rediss:// connection string
REDIS_URL=

# ── Auth (required) ────────────────────────────────────────────────────
# Minimum 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=
# Access token lifetime (jsonwebtoken duration string)
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token lifetime in days
JWT_REFRESH_EXPIRES_IN_DAYS=30

# ── AI — Gemini (optional) ─────────────────────────────────────────────
# Empty = AI features (suggestions, summaries) disabled with a warning.
GEMINI_API_KEY=

# ── Email — Resend (optional) ──────────────────────────────────────────
# Empty = outbound email disabled with a warning.
RESEND_API_KEY=

# ── File storage ───────────────────────────────────────────────────────
# local (filesystem) | s3
STORAGE_PROVIDER=local
STORAGE_MAX_FILE_SIZE_MB=10
# Directory for the local provider, relative to the API working directory
STORAGE_LOCAL_DIR=storage
# Required only when STORAGE_PROVIDER=s3 — if incomplete, uploads are
# unavailable (health reports "degraded") but the app keeps running.
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── HTTP (optional) ────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins. Empty = reflect any
# origin, which the embeddable chat widget needs when it runs on
# arbitrary customer sites (safe: auth is Bearer-token, not cookies).
CORS_ORIGINS=
# Public dashboard URL — startup logging only
DASHBOARD_URL=http://localhost:3000

# ── Dashboard (put these in apps/web/.env.local for local dev) ─────────
# Browser-reachable API URL, inlined into the client bundle at build time
NEXT_PUBLIC_API_URL=http://localhost:4000
# Workspace the /demo and /help pages use for the widget + knowledge base
NEXT_PUBLIC_DEMO_WORKSPACE_ID=
