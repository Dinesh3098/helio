{
  "name": "helio",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.2.0",
      "flatted": "^3.4.2",
      "minimatch@^3": "^3.1.4",
      "minimatch@^9": "^9.0.7",
      "picomatch@^2": "^2.3.2",
      "picomatch@^4": "^4.0.4",
      "js-yaml@^4": "^4.2.0",
      "ajv@^6": "^6.14.0",
      "brace-expansion@^1": "^1.1.13",
      "brace-expansion@^2": "^2.0.3",
      "postcss@^8": "^8.5.10"
    }
  }
}
