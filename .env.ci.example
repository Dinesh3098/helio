# CI-safe environment for docker compose verification.
#
# Every value is a mock — nothing here is a real credential and nothing
# talks to external services. The stack boots fully self-contained
# (bundled PostgreSQL + Redis, local file storage). CI copies this file
# to .env before `docker compose build && docker compose up`.

# ── PostgreSQL container (internal network only) ───────────────────────
POSTGRES_USER=helio_ci
POSTGRES_PASSWORD=ci-only-not-a-real-password
POSTGRES_DB=helio_ci

# ── Auth (mock, satisfies the 32-char minimum) ─────────────────────────
JWT_SECRET=ci-mock-jwt-secret-0123456789abcdefghijklmnopqrstuvwxyz
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

# ── Optional providers (mock keys — never called during CI boot;
#    requests would fail at the provider, the app still runs) ───────────
GEMINI_API_KEY=ci-mock-gemini-key
RESEND_API_KEY=ci-mock-resend-key

# ── Storage: local filesystem, so the mock AWS values are never used ───
STORAGE_PROVIDER=local
STORAGE_MAX_FILE_SIZE_MB=10
AWS_REGION=us-east-1
AWS_S3_BUCKET=ci-mock-bucket
AWS_ACCESS_KEY_ID=ci-mock-access-key
AWS_SECRET_ACCESS_KEY=ci-mock-secret-key

# ── URLs & ports ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_DEMO_WORKSPACE_ID=
DASHBOARD_URL=http://localhost:3000
CORS_ORIGINS=
API_PORT=4000
WEB_PORT=3000
