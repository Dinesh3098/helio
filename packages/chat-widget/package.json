{
  "name": "@helio/chat-widget",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build -c vite.loader.config.ts && vite build -c vite.app.config.ts && node scripts/sync-demo.mjs",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "devDependencies": {
    "@helio/config": "workspace:*",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "jsdom": "^25.0.1",
    "typescript": "5.9.2",
    "vite": "^8.1.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "preact": "^10.29.4",
    "socket.io-client": "^4.8.3"
  }
}
