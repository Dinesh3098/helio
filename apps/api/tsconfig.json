{
  "extends": "@helio/config/typescript/base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // TypeORM hydrates entity properties at runtime; the initializer
    // check only produces false positives on entity classes.
    "strictPropertyInitialization": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "outDir": "./dist"
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist"]
}
