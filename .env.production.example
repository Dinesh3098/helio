# Helio — production environment for docker compose.
#
#   cp .env.production.example .env
#   # fill in JWT_SECRET (and any provider keys you have)
#   docker compose up --build
#
# docker-compose.yml reads this file for variable interpolation and
# injects the values into the containers. DATABASE_URL and REDIS_URL are
# composed automatically from the service names (postgres, redis) — you
# do not set them here.

# ── PostgreSQL container ───────────────────────────────────────────────
# Credentials for the bundled postgres service. Change the password for
# any deployment that outlives a review. The database is only reachable
# on the internal Docker network.
POSTGRES_USER=helio
POSTGRES_PASSWORD=helio
POSTGRES_DB=helio

# ── Auth (REQUIRED — compose refuses to start without it) ──────────────
# Minimum 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

# ── Optional providers ─────────────────────────────────────────────────
# Leave empty to run without the feature (startup logs a warning, health
# reports "degraded", everything else works).
# Gemini — AI suggestions/summaries
GEMINI_API_KEY=
# Resend — outbound email
RESEND_API_KEY=

# ── File storage ───────────────────────────────────────────────────────
# local = files persist in the api_storage Docker volume
# s3    = AWS S3 (fill in the AWS_* block below)
STORAGE_PROVIDER=local
STORAGE_MAX_FILE_SIZE_MB=10
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── URLs & ports ───────────────────────────────────────────────────────
# Browser-reachable API URL — baked into the dashboard at build time.
# When deploying on a server, set this to the public API origin
# (e.g. https://api.example.com) and rebuild: docker compose build web
NEXT_PUBLIC_API_URL=http://localhost:4000
# Workspace id for the /demo page widget and /help center (optional;
# create a workspace first, then rebuild web with the id)
NEXT_PUBLIC_DEMO_WORKSPACE_ID=
# Public dashboard URL (startup logging)
DASHBOARD_URL=http://localhost:3000
# Comma-separated browser-origin allowlist. Empty = any origin, which
# the embeddable chat widget needs on arbitrary customer sites (safe:
# Bearer-token auth, no cookies). If you set it, include the dashboard
# origin AND every site that embeds the widget.
CORS_ORIGINS=
# Host ports to publish
API_PORT=4000
WEB_PORT=3000
